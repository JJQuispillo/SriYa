# ─── Base de datos ────────────────────────────────────────
# billing_user es el rol propietario/bootstrap: ejecuta migraciones y
# provisiona los roles de runtime.
BILLING_DB_USER=billing_user
BILLING_DB_PASSWORD=changeme

# ─── Roles de runtime (aislamiento multi-emisor / RLS) ────
# La app NO corre como propietario: deriva estos dos roles a partir de la
# cadena base. billing_app está restringido por Row-Level Security;
# billing_privileged (BYPASSRLS) solo sirve las rutas cross-tenant internas.
# Cámbialas por valores aleatorios en producción.
BILLING_APP_DB_PASSWORD=changeme-billing-app
BILLING_PRIVILEGED_DB_PASSWORD=changeme-billing-privileged

# ─── Autenticación servicio-a-servicio ────────────────────
# Este token lo usa el Backend API para llamar al billing.
# En producción debe ser un valor largo y aleatorio.
SERVICE_AUTH_TOKEN=changeme-generate-a-long-random-token

# ─── Encriptación de claves de certificados (.p12) ────────
# Cifra en reposo las llaves privadas de los certificados SRI.
# OBLIGATORIO antes de subir cualquier certificado. 32+ caracteres.
# Genera una con: openssl rand -base64 32
ENCRYPTION_KEY=changeme-generate-with-openssl-rand-base64-32

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGIN_0=http://localhost:3000

# ─── Puerto del API (opcional, default 8080) ──────────────
# BILLING_API_PORT=8080

# ─── SRI (opcional, ya tienen defaults en docker-compose) ─
# SRI_TIMEOUT=30
# SRI_MAX_RETRIES=3
